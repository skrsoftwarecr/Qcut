rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isOwner(uid) {
      return request.auth != null && request.auth.uid == uid;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function userProfile() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function isAdminOfBusiness(businessId) {
      return isSignedIn() &&
        request.auth.uid == businessId;
    }

    function isBarberOfBusiness(businessId) {
      return isSignedIn() &&
        userProfile().exists() &&
        userProfile().data.role == 'barber' &&
        userProfile().data.businessId == businessId;
    }

    function isBusinessMember(businessId) {
      return isAdminOfBusiness(businessId) || isBarberOfBusiness(businessId);
    }

    function isLinkedBarberInBusiness(businessId, barberId) {
      return isSignedIn() &&
        userProfile().exists() &&
        userProfile().data.role == 'barber' &&
        userProfile().data.businessId == businessId &&
        userProfile().data.barberId == barberId;
    }

    function hasOnlyKeys(allowedKeys) {
      return request.resource.data.keys().hasOnly(allowedKeys);
    }

    function isValidPublicAppointment() {
      return request.resource.data.clientName is string &&
        request.resource.data.clientName.size() > 0 &&
        request.resource.data.clientName.size() <= 128 &&
        request.resource.data.clientEmail is string &&
        request.resource.data.clientPhone is string &&
        request.resource.data.clientPhone.size() >= 6 &&
        request.resource.data.date is timestamp &&
        request.resource.data.time is string &&
        request.resource.data.barberId is string &&
        request.resource.data.barberName is string &&
        request.resource.data.confirmationStatus is string &&
        request.resource.data.confirmationToken is string &&
        request.resource.data.confirmationTokenExpiry is timestamp &&
        (request.resource.data.status == 'pending' || request.resource.data.status == 'confirmed') &&
        hasOnlyKeys([
          'clientName', 'clientPhone', 'clientEmail', 'notes', 'date',
          'status', 'barberId', 'barberName', 'barberEmail', 'createdAt',
          'updatedAt', 'reminderSent', 'time', 'confirmationStatus',
          'confirmationToken', 'confirmationTokenExpiry'
        ]);
    }

    function isValidTokenBasedAppointmentUpdate() {
      return !isSignedIn() &&
        resource.data.confirmationToken is string &&
        request.resource.data.confirmationToken == resource.data.confirmationToken &&
        request.resource.data.clientName == resource.data.clientName &&
        request.resource.data.clientPhone == resource.data.clientPhone &&
        request.resource.data.clientEmail == resource.data.clientEmail &&
        request.resource.data.notes == resource.data.notes &&
        request.resource.data.date == resource.data.date &&
        request.resource.data.time == resource.data.time &&
        request.resource.data.barberId == resource.data.barberId &&
        request.resource.data.barberName == resource.data.barberName &&
        request.resource.data.barberEmail == resource.data.barberEmail &&
        request.resource.data.createdAt == resource.data.createdAt &&
        request.resource.data.confirmationTokenExpiry == resource.data.confirmationTokenExpiry &&
        request.resource.data.updatedAt is timestamp &&
        (request.resource.data.reminderSent == resource.data.reminderSent ||
          !(request.resource.data.reminderSent is bool) ||
          !(resource.data.reminderSent is bool)) &&
        (
          (request.resource.data.confirmationStatus == 'confirmed' &&
            request.resource.data.status == 'confirmed' &&
            resource.data.status == 'confirmed' &&
            (resource.data.confirmationStatus == 'pending' || resource.data.confirmationStatus == 'not_requested')) ||
          (request.resource.data.confirmationStatus == 'cancelled' &&
            request.resource.data.status == 'cancelled')
        );
    }

    // 1) Perfil de usuario
    match /users/{uid} {
      allow read, write: if isOwner(uid);
      allow create: if isSignedIn() &&
        request.resource.data.role == 'barber' &&
        request.resource.data.businessId == request.auth.uid;
    }

    // 2) Configuracion general de la barberia (public read for booking page)
    match /barbers/{uid}/config/barberdata {
      allow read: if true;
      allow write: if isAdminOfBusiness(uid);
    }

    // 2.1) Configuracion personal de horario por barbero (public read for booking page)
    match /barbers/{uid}/barberConfigs/{barberId} {
      allow read: if true;
      allow write: if isAdminOfBusiness(uid)
        || (
          isSignedIn()
          && (
            request.resource.data.barberUid == request.auth.uid
            || (userProfile().exists() && request.resource.data.barberId == userProfile().data.barberId)
            || (userProfile().exists() && barberId == userProfile().data.barberId)
          )
        );
    }

    // 3) Citas — lectura pública para disponibilidad en el formulario de citas.
    match /barbers/{uid}/appointments/{appointment} {
      allow read: if true;
      allow create: if isValidPublicAppointment();
      allow update: if isBusinessMember(uid) || isValidTokenBasedAppointmentUpdate();
      allow delete: if isAdminOfBusiness(uid);
    }

    // 4) Bloqueos de horario (public read for booking calendar)
    match /barbers/{uid}/bloqueos/{blockId} {
      allow read: if true;
      allow create, update: if isAdminOfBusiness(uid)
        || (
          isSignedIn()
          && (
            request.resource.data.barberUid == request.auth.uid
            || (userProfile().exists() && request.resource.data.barberId == userProfile().data.barberId)
          )
        );

      allow delete: if isAdminOfBusiness(uid)
        || (
          isSignedIn()
          && (
            resource.data.barberUid == request.auth.uid
            || (userProfile().exists() && resource.data.barberId == userProfile().data.barberId)
          )
        );
    }

    // 5) Notificaciones (solo miembros del negocio)
    match /barbers/{uid}/notifications/{notifId} {
      allow create: if isBusinessMember(uid);
      allow read, update, delete: if isBusinessMember(uid);
    }

    // 6) Otras configs del dueño
    match /barbers/{uid}/config/{document=**} {
      allow read, write: if isAdminOfBusiness(uid);
    }

    // Denegar por defecto
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
