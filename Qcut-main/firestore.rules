rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isOwner(uid) {
      return request.auth != null && request.auth.uid == uid;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function userProfile() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function isAdminOfBusiness(businessId) {
      return isSignedIn() &&
        request.auth.uid == businessId;
    }

    function isBarberOfBusiness(businessId) {
      return isSignedIn() &&
        userProfile().exists() &&
        userProfile().data.role == 'barber' &&
        userProfile().data.businessId == businessId;
    }

    function isBusinessMember(businessId) {
      return isAdminOfBusiness(businessId) || isBarberOfBusiness(businessId);
    }

    function isLinkedBarberInBusiness(businessId, barberId) {
      return isSignedIn() &&
        userProfile().exists() &&
        userProfile().data.role == 'barber' &&
        userProfile().data.businessId == businessId &&
        userProfile().data.barberId == barberId;
    }

    function hasOnlyKeys(allowedKeys) {
      return request.resource.data.keys().hasOnly(allowedKeys);
    }

    function isValidPublicAppointment() {
      return request.resource.data.clientName is string &&
        request.resource.data.clientEmail is string &&
        request.resource.data.clientPhone is string &&
        request.resource.data.date is timestamp &&
        request.resource.data.barberId is string &&
        request.resource.data.barberName is string &&
        (request.resource.data.status == 'pending' || request.resource.data.status == 'confirmed') &&
        hasOnlyKeys([
          'clientName', 'clientPhone', 'clientEmail', 'notes', 'date',
          'status', 'barberId', 'barberName', 'barberEmail', 'createdAt',
          'updatedAt', 'reminderSent'
        ]);
    }

    // 1) Perfil de usuario
    match /users/{uid} {
      allow read, write: if isOwner(uid);
      allow create: if isSignedIn() &&
        request.resource.data.role == 'barber' &&
        request.resource.data.businessId == request.auth.uid;
    }

    // 2) Configuracion general de la barberia
    match /barbers/{uid}/config/barberdata {
      allow read: if true;
      allow write: if isAdminOfBusiness(uid);
    }

    // 2.1) Configuracion personal de horario por barbero
    match /barbers/{uid}/barberConfigs/{barberId} {
      allow read: if true;
      allow write: if isAdminOfBusiness(uid)
        || (
          isSignedIn()
          && (
            request.resource.data.barberUid == request.auth.uid
            || (userProfile().exists() && request.resource.data.barberId == userProfile().data.barberId)
            || (userProfile().exists() && barberId == userProfile().data.barberId)
          )
        );
    }

    // 3a) Lectura de citas via collectionGroup (necesaria para buscar por confirmationToken)
    match /{path=**}/appointments/{appointment} {
      allow read: if true;
    }

    // 3) Citas
    match /barbers/{uid}/appointments/{appointment} {
      allow read: if true;
      allow create: if isValidPublicAppointment();

      // Regla temporalmente abierta para descartar bloqueos de permisos
      // en confirmacion por enlace y solicitudes de email.
      allow update: if true;

      allow delete: if isAdminOfBusiness(uid);
    }

    // 4) Bloqueos de horario
    match /barbers/{uid}/bloqueos/{blockId} {
      allow read: if true;
      allow create, update: if isAdminOfBusiness(uid)
        || (
          isSignedIn()
          && (
            request.resource.data.barberUid == request.auth.uid
            || (userProfile().exists() && request.resource.data.barberId == userProfile().data.barberId)
          )
        );

      allow delete: if isAdminOfBusiness(uid)
        || (
          isSignedIn()
          && (
            resource.data.barberUid == request.auth.uid
            || (userProfile().exists() && resource.data.barberId == userProfile().data.barberId)
          )
        );
    }

    // 5) Notificaciones
    match /barbers/{uid}/notifications/{notifId} {
      allow create: if true;
      allow read, update, delete: if isBusinessMember(uid);
    }

    // 6) Otras configs del dueno
    match /barbers/{uid}/config/{document=**} {
      allow read, write: if isAdminOfBusiness(uid);
    }

    // Denegar por defecto
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
